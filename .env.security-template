# =============================================================================
# SECURITY TEMPLATE - Environment Variables Configuration
# =============================================================================
# 
# This template helps ensure secure configuration of environment variables.
# Copy relevant sections to your .env file and replace with actual values.
#
# IMPORTANT: Never commit .env files to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Backend Configuration (.env in /backend directory)
# -----------------------------------------------------------------------------

# Server Configuration
PORT=3001
NODE_ENV=development  # Options: development, production, test

# Database Configuration
DATABASE_PATH=./data/beers.db  # SQLite database file path

# CORS Configuration
CORS_ORIGIN=http://localhost:5173  # Frontend URL for CORS
# For production, use your actual domain:
# CORS_ORIGIN=https://yourdomain.com

# -----------------------------------------------------------------------------
# Frontend Configuration (.env in /frontend directory)
# -----------------------------------------------------------------------------

# API Configuration
VITE_API_URL=http://localhost:3001  # Backend API URL
# For production, use your actual API domain:
# VITE_API_URL=https://api.yourdomain.com

# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# 1. Keep Secrets Secret
#    - Never commit .env files
#    - Don't share .env files via email or chat
#    - Use different values for dev/staging/production
#
# 2. Production Checklist
#    - Use HTTPS for all URLs
#    - Set NODE_ENV=production
#    - Use specific CORS origins (not *)
#    - Secure database file permissions
#    - Enable rate limiting
#    - Add security headers
#
# 3. Key Management
#    - If you add API keys, store them here
#    - Rotate keys regularly
#    - Use key management service for production
#    - Example:
#    # API_KEY=your_secret_api_key_here
#    # JWT_SECRET=your_jwt_secret_here
#
# 4. Database Security
#    - Use strong database passwords (if switching to PostgreSQL/MySQL)
#    - Restrict database access to application only
#    - Enable SSL for database connections in production
#    - Example for PostgreSQL:
#    # DATABASE_URL=postgresql://user:password@host:5432/dbname?ssl=true
#
# 5. Monitoring
#    - Log access to environment variables
#    - Monitor for unusual configuration changes
#    - Set up alerts for security events
#
# =============================================================================
